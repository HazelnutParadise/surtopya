# Example environment variables for local development
# docker-compose reads .env; keep runtime config centralized here.

# Frontend
INTERNAL_API_URL=http://api:8080/v1
PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
DATASETS_DIR=/data/datasets
NEXT_PUBLIC_BASE_URL=http://localhost:3000
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_COOKIE_SECRET=complex_password_at_least_32_characters_long

# Docker published ports (host side)
WEB_HOST_PORT=3000
API_HOST_PORT=8000
POSTGRES_HOST_PORT=5432

# Backend / Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=surtopya
DB_SSLMODE=disable

# Auth
SURTOPYA_ENV=development
JWT_SECRET=development-secret-key
ALLOW_UNVERIFIED_JWT=true
ALLOWED_ORIGINS=http://localhost:3000

# Web security (bootstrap protection)
REQUIRE_BOOTSTRAP_AUTH=false

# Points
# Membership monthly points and survey base completion points are configured in admin settings.

# Logto (recommended for production)
# API resource indicator in Logto Console > API resources (must match backend LOGTO_AUDIENCE check)
LOGTO_JWKS_URL=
LOGTO_ISSUER=
LOGTO_AUDIENCE=

# Docker bind mounts
# Use different host paths per environment via --env-file.
API_DATASETS_HOST_PATH=./mounts/api/datasets
POSTGRES_DATA_HOST_PATH=./mounts/postgres/data

# Migrations
# API reads SQL migration files from this directory inside the container.
MIGRATIONS_DIR=./migrations
