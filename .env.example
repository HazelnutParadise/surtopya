# Example environment variables for local development
# docker-compose reads .env; keep runtime config centralized here.

# Frontend
INTERNAL_API_URL=http://api:8080/api/v1
PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
DATASETS_DIR=/data/datasets
NEXT_PUBLIC_BASE_URL=http://localhost:3000
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_COOKIE_SECRET=complex_password_at_least_32_characters_long

# Backend / Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=surtopya
DB_SSLMODE=disable

# Auth
SURTOPYA_ENV=development
JWT_SECRET=development-secret-key
ALLOW_UNVERIFIED_JWT=true
ALLOWED_ORIGINS=http://localhost:3000

# Web security (bootstrap protection)
REQUIRE_BOOTSTRAP_AUTH=false

# Supabase (optional; required only if using Supabase auth flows)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Points
# Monthly base points for Pro users. Set <= 0 to disable.
PRO_MONTHLY_POINTS=100

# Survey rewards
# Base points granted to authenticated users on survey completion.
SURVEY_BASE_POINTS=1

# Logto (recommended for production)
LOGTO_JWKS_URL=
LOGTO_ISSUER=
LOGTO_AUDIENCE=

# Migrations
# API reads SQL migration files from this directory inside the container.
MIGRATIONS_DIR=./migrations
